---
import { Button, Icon } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'
import PageLayout from '@/layouts/BaseLayout.astro'
import { integ } from '@/site-config'

import VaultContents from './VaultContents.astro'

const meta = {
  title: 'Vault - Knowledge Base',
  description: 'Vault content documentation'
}
---

<PageLayout {meta}>
  <Button title='Back' href='/' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium'>My Knowledge Vault</h1>
    </div>
    <div>
      <p>
        This contains my personal notes on various topics like Cyber security, Web development, Computer science and more. It serves as a knowledge base for quick reference and learning.
      </p>
    </div>
    <div id='content' class={cn('animate mt-8 max-w-none md:min-w-[45ch]', integ.typography.class)}>
      <VaultContents title="Content" />

      <h2 class='text-xl font-medium'>Feedback</h2>
      <p>
        If you have any problems, you can check <a
          href='https://github.com/nahilrasheed'
          target='_blank'>Github Issues</a
        > for community support.
      </p>
      <h2 class='text-xl font-medium'>RSS Feed</h2>
      <p>
        <a href='/vault/rss.xml' target='_blank'><Icon name='rss' /> </a>
      </p>
    </div>
  </main>
</PageLayout>
